{
  "name": "devextreme-cli-monorepo",
  "version": "1.2.7",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "test": "pnpm -r run test",
    "test-dev": "pnpm --filter devextreme-cli run test-dev",
    "create-template": "pnpm --filter devextreme-cli run create-template",
    "lint-template": "pnpm --filter devextreme-cli run lint-template",
    "test-template": "pnpm --filter devextreme-cli run test-template",
    "test-themebuilder": "pnpm --filter devextreme-cli run test-themebuilder",
    "update-template": "node ./templates-generator/index.js",
    "regenerate-nextjs-apps": "node ./scripts/regenerate-nextjs-apps/index.js",
    "lint": "pnpm -r run lint"
  },
  "devDependencies": {
    "@angular-eslint/schematics": "^0.2.0-beta.1",
    "pre-commit": "^1.2.2",
    "puppeteer": "^24.42.0"
  },
  "pre-commit": "lint",
  "pnpm": {
    "overrides": {
      "form-data@>=4.0.0 <4.0.4": ">=4.0.5",
      "tar-fs@>=3.0.0 <3.1.1": ">=3.1.2",
      "ws@>=8.0.0 <8.17.1": ">=8.20.0",
      "cross-spawn": "7.0.6",
      "js-yaml@>=4.0.0 <4.1.1": "4.1.1",
      "tar@<=7.5.10": "~7.5.13",
      "minimatch": "3.1.5",
      "@babel/traverse@<7.23.2": ">=7.29.0",
      "braces@<3.0.3": ">=3.0.3",
      "flatted": "^3.4.2",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>4.0.0": "^4.0.4"
    }
  }
}

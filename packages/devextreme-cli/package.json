{
  "name": "devextreme-cli",
  "version": "1.16.0",
  "description": "DevExtreme CLI",
  "keywords": [
    "devexpress",
    "devextreme",
    "cli",
    "themebuilder",
    "theme",
    "application"
  ],
  "bin": {
    "devextreme": "index.js"
  },
  "engines": {
    "node": ">20.19.0",
    "npm": ">9.6.0",
    "yarn": ">1.21"
  },
  "files": [
    "src/**/*",
    "index.js"
  ],
  "scripts": {
    "lint": "eslint ./",
    "test": "pnpm run create-template && pnpm run lint-template && pnpm run test-template && pnpm run test-themebuilder",
    "create-template": "node ./testing/creating.js",
    "lint-template": "node ./testing/linting.js",
    "test-template": "node ./testing/testing.js",
    "test-dev": "cross-env TEST_MODE=dev jest",
    "test-themebuilder": "jest --config=./jest-themebuilder.config.js --runInBand",
    "docker:build": "docker build --rm -f \"testing/docker/Dockerfile\" -t devextreme-cli:latest \"testing/docker\" --progress=plain",
    "docker:run": "docker run --rm -d  -p 9222:9222/tcp devextreme-cli:latest"
  },
  "author": "Developer Express Inc.",
  "repository": "https://github.com/DevExpress/devextreme-cli",
  "license": "MIT",
  "dependencies": {
    "@yarnpkg/lockfile": "^1.1.0",
    "import-cwd": "^3.0.0",
    "less": "3.13.1",
    "minimist": "^1.2.8",
    "mustache": "^3.2.1",
    "prompts": "^2.4.2",
    "sass": "^1.101.0",
    "semver": "^5.7.2",
    "strip-bom": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/node": "20.19.43",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "create-vite": "7.1.3",
    "cross-env": "^5.2.1",
    "eslint": "^9.39.4",
    "eslint-config-angular": "^0.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-angular": "^4.1.0",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "jest-image-snapshot": "^6.5.2",
    "prettier": "^2.8.8",
    "rimraf": "^2.7.1",
    "tree-kill": "^1.2.2",
    "tree-kill-promise": "^1.0.12",
    "typescript": "^4.9.5",
    "wait-on": "8.0.5"
  }
}
